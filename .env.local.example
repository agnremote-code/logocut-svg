VECTORIZER_API_ID="your-api-id"
VECTORIZER_API_SECRET="your-api-secret"

STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="whsec_your-stripe-webhook-secret"

# Optional for local durable Blob testing.
# If omitted locally, the app falls back to in-memory storage.
BLOB_READ_WRITE_TOKEN="vercel-blob-read-write-token"

# In Vercel production, a connected Blob store may expose this automatically
# through system environment variables instead of BLOB_READ_WRITE_TOKEN.
# BLOB_STORE_ID="vercel-blob-store-id"
